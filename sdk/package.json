{
  "name": "@stellaryield/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for StellarYield Soroban vault and factory contracts",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@stellar/freighter-api": "^3.1.0",
    "@stellar/stellar-sdk": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0"
  },
  "keywords": [
    "stellar",
    "soroban",
    "stellaryield",
    "defi",
    "rwa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/StellarYield/StellarYield-Contracts.git",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public"
  }
}
